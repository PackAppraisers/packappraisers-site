<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Projects — Pack Appraisers</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Josefin+Sans:wght@200;300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 3rem 1.5rem 4rem;
      font-family: 'Josefin Sans', sans-serif;
      font-weight: 300;
      letter-spacing: 0.05em;
    }

    .logo {
      width: min(550px, 90vw);
      display: block;
      margin: 0 auto 1rem;
      animation: fadeUp 0.9s ease both;
    }

    nav {
      display: flex;
      gap: 2rem;
      margin-bottom: 3rem;
      animation: fadeUp 0.9s 0.1s ease both;
    }

    nav a {
      color: #fff;
      text-decoration: none;
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      opacity: 0.5;
      transition: opacity 0.2s;
    }

    nav a:hover { opacity: 1; }
    nav a.active { opacity: 1; border-bottom: 1px solid #fff; padding-bottom: 2px; }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 400;
      color: #fff;
      text-align: center;
      margin-bottom: 2.5rem;
      animation: fadeUp 0.9s 0.2s ease both;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2px;
      width: 100%;
      max-width: 1000px;
      animation: fadeUp 0.9s 0.3s ease both;
    }

    .grid img {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
      filter: grayscale(10%);
      transition: filter 0.3s, transform 0.3s;
    }

    .grid img:hover {
      filter: grayscale(0%);
      transform: scale(1.01);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <a href="index.html">
    <img class="logo" src="data:image/png;base64," alt="Pack Appraisers" />
  </a>

  <nav>
    <a href="index.html">Home</a>
    <a href="projects.html" class="active">Projects</a>
  </nav>

  <h1>Our Work</h1>

  <div class="grid">
    <img src="data:image/jpeg;base64," alt="Project" />
  </div>

</body>
</html>
